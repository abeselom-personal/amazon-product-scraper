# Database Configuration
DB_PATH=./data/products.db
DEDUP_TTL_DAYS=7

# Scraper Configuration
# Leave empty to auto-detect (checks common Chrome/Chromium locations)
CHROMIUM_PATH=
MAX_RETRIES=3
RETRY_DELAY_MS=2000
RATE_LIMIT_MS=1000
SCRAPER_TIMEOUT=60000

# AI Provider Configuration
# Options: google (Google AI Studio / Gemini) | mock (heuristic fallback)
AI_PROVIDER=google

# Google AI Studio (Gemini) — required when AI_PROVIDER=google
GOOGLE_AI_STUDIO_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash
GOOGLE_AI_TIMEOUT_MS=30000
GOOGLE_AI_MAX_RETRIES=5
GOOGLE_AI_USE_IMAGE=true

# Rate limiting (keep conservative defaults to reduce 429s).
# Keep RPM below the limit and concurrency low to avoid 429s.
GOOGLE_AI_RPM=10
GOOGLE_AI_MAX_CONCURRENCY=2
GOOGLE_AI_DEFAULT_COOLDOWN_MS=60000
# After this many consecutive 429s, stop calling Gemini for the remainder of the run (use fallback).
GOOGLE_AI_MAX_CONSECUTIVE_429=5

# Local AI (legacy / fallback)
AI_MODEL_PATH=./models/qwen2.5-small
AI_BATCH_SIZE=5
AI_MAX_TOKENS=512
AI_TEMPERATURE=0.1
AI_CONFIDENCE_THRESHOLD=0.7

# Product filters (price in GBP)
# Min-price: skip cheap items below this threshold (set ENABLE_MIN_PRICE_FILTER=false to disable)
MINIMUM_PRODUCT_PRICE_GBP=1
ENABLE_MIN_PRICE_FILTER=true
# Max-price: skip items more expensive than this threshold (set ENABLE_MAX_PRICE_FILTER=false to disable)
MAXIMUM_PRODUCT_PRICE_GBP=15
ENABLE_MAX_PRICE_FILTER=true
# AI shipping viability threshold used in prompt/scoring
MAX_SHIPPABLE_WEIGHT_GRAMS=100

# Category-based scraping
# Comma-separated list of categories enabled in the UI / API
CATEGORIES_ENABLED=Misc,Hardware

# Optional: visit each product detail page to gather full image gallery (slower but more images)
FETCH_PDP_IMAGES=false
MAX_IMAGES_PER_PRODUCT=6

# Scoring Weights (must sum to 1.0)
WEIGHT_BULK=0.30
WEIGHT_DEMAND=0.25
WEIGHT_TRUST=0.20
WEIGHT_UNIT_MARGIN=0.25

# Export Configuration
EXPORT_TOP_N=100
EXPORT_PATH=./exports

# Server Configuration
PORT=3000
